# ============================================================
# Variables de entorno para el Backend (MySQL + Spring Boot)
# Copiar como .env y completar con valores reales
# NO subir el archivo .env al repositorio
# ============================================================

# Base de datos MySQL
# DB_ENDPOINT se resuelve automáticamente como "db" (nombre del servicio Docker)
DB_NAME=citt_despachos
DB_USERNAME=innovauser
DB_PASSWORD=<password_seguro_aqui>

# Puerto donde se expone la API (debe coincidir con server.port=8081)
BACKEND_PORT=8081

# Imagen Docker Hub (usuario/nombre-imagen)
DOCKER_IMAGE=tuusuario/innovatech-despacho-backend:latest
